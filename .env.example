# ──────────────────────────────────────────────
# ZeroClaw — Student Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# ──────────────────────────────────────────────

# REQUIRED — Telegram bot token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# REQUIRED — Your Telegram user ID (get from @userinfobot on Telegram)
TELEGRAM_USER_ID=

# LLM Provider: "openai" or "copilot"
LLM_PROVIDER=openai

# Model name (gpt-4o for OpenAI, gpt-5.2 for Copilot)
LLM_MODEL=gpt-4o

# REQUIRED for OpenAI provider — your API key from platform.openai.com
OPENAI_API_KEY=
